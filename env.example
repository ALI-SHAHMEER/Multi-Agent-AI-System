# ── Required ──────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── External APIs (Part H) ────────────────────────────────
NEWS_API_KEY=your_newsapi_key_here        # https://newsapi.org  (free tier)
# Semantic Scholar is free with no key needed

# ── MCP Servers (Part G) ─────────────────────────────────
GOOGLE_DRIVE_FOLDER_ID=your_folder_id    # Google Drive folder for papers
FILESYSTEM_BASE_PATH=./data              # Local data directory

# ── Optional ──────────────────────────────────────────────
TAVILY_API_KEY=tvly-...                  # Tavily web search (optional)
